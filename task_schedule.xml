      </ScheduleByWeek>
    </CalendarTrigger>
  </Triggers>
  <Actions Context="Author">
    <Exec>
      <Command>C:\Users\corr8\Desktop\obsidian-vault\Stock Market Bot\venv\Scripts\python.exe</Command>
      <Arguments>C:\Users\corr8\Desktop\obsidian-vault\Stock Market Bot\main.py</Arguments>
      <WorkingDirectory>C:\Users\corr8\Desktop\obsidian-vault\Stock Market Bot</WorkingDirectory>
    </Exec>
  </Actions>
