<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.3" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Report settimanale mercati azionari — ogni lunedi alle 14:00 Bali (08:00 IT)</Description>
    <URI>\StockMarketBot</URI>
  </RegistrationInfo>
  <Principals>
    <Principal id="Author">
      <UserId>S-1-5-21-3296727851-1170441352-78878944-1006</UserId>
      <LogonType>InteractiveToken</LogonType>
